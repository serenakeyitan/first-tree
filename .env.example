# Eval configuration — copy to .env and customize.
# Environment variables take precedence over .env values.

# Local git repo cache directory (speeds up repeated eval runs)
EVALS_REPO_CACHE=~/.context-tree/repo-cache

# Directory for storing eval results
EVALS_STORE_DIR=~/.context-tree/evals

# Context tree repo slug (e.g. agent-team-foundation/eval-context-trees)
EVALS_TREE_REPO=

# Agent model and CLI
EVALS_MODEL=claude-sonnet-4-6
EVALS_CLI=claude-code

# --- Timeouts (milliseconds) ---

# Git network operations
# EVALS_TIMEOUT_GIT_CLONE=300000
# EVALS_TIMEOUT_GIT_FETCH=120000
# EVALS_TIMEOUT_GIT_LS_REMOTE=30000
# EVALS_TIMEOUT_GIT_PUSH=60000

# Git local operations
# EVALS_TIMEOUT_GIT_CHECKOUT=120000
# EVALS_TIMEOUT_GIT_CLEAN=30000
# EVALS_TIMEOUT_GIT_RESET=30000
# EVALS_TIMEOUT_COPY=120000
# EVALS_TIMEOUT_GIT_LOG=10000
# EVALS_TIMEOUT_GIT_INFO=5000

# Setup & build
# EVALS_TIMEOUT_SETUP=300000
# EVALS_TIMEOUT_INSTALL=120000
# EVALS_TIMEOUT_BUILD=60000

# Agent & verification
# EVALS_TIMEOUT_SESSION=600000
# EVALS_TIMEOUT_POPULATE=900000
# EVALS_TIMEOUT_VERIFY=120000
